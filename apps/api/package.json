{
    "name":  "@vpos/api",
    "version":  "0.1.0",
    "private":  true,
    "scripts":  {
                    "start":  "node dist/apps/api/src/main.js",
                    "start:dev":  "ts-node-dev --respawn --transpile-only src/main.ts",
                    "build":  "tsc -p tsconfig.build.json",
                    "test":  "jest --config test/jest-e2e.json",
                    "test:watch":  "jest --config test/jest-e2e.json --watch",
                    "db:create":  "powershell -ExecutionPolicy Bypass -File ./scripts/create-local-db.ps1",
                    "db:reset:fresh": "node ./scripts/reset-fresh-start.mjs",
                    "db:reset:owner-only": "node ./scripts/reset-fresh-start.mjs && node ./scripts/cleanup-seeded-tenants.mjs --all-dedicated",
                    "db:migrate:all": "node ./scripts/migrate-all-datastores.mjs",
                    "ops:backup": "powershell -ExecutionPolicy Bypass -File ./scripts/backup-postgres.ps1",
                    "ops:retention:dry-run": "node ./scripts/retention-maintenance.mjs --years 7",
                    "ops:retention:apply": "node ./scripts/retention-maintenance.mjs --years 7 --apply",
                    "ops:security:check": "node ./scripts/security-checklist-audit.mjs --strict",
                    "ops:entitlements:health": "node ./scripts/entitlement-sync-health.mjs --strict",
                    "ops:transfers:health": "node ./scripts/transfer-ops-health.mjs --strict",
                    "ops:idempotency:cleanup:dry-run": "node ./scripts/cleanup-idempotency-keys.mjs --days 90",
                    "ops:idempotency:cleanup:apply": "node ./scripts/cleanup-idempotency-keys.mjs --days 90 --apply",
                    "ops:hybrid:health": "node ./scripts/hybrid-datastore-health.mjs",
                    "ops:datastore-key-rotate:dry-run": "node ./scripts/rotate-datastore-registry-keys.mjs",
                    "ops:datastore-key-rotate:apply": "node ./scripts/rotate-datastore-registry-keys.mjs --apply",
                    "ops:maintenance": "powershell -ExecutionPolicy Bypass -File ./scripts/run-ops-maintenance.ps1",
                    "tenants:cleanup:seeded":  "node ./scripts/cleanup-seeded-tenants.mjs",
                    "prisma:generate":  "prisma generate",
                    "prisma:migrate":  "prisma migrate dev",
                    "prisma:migrate:deploy":  "prisma migrate deploy",
                    "prisma:seed":  "tsx prisma/seed.ts",
                    "typecheck":  "tsc -p tsconfig.json --noEmit"
                },
    "dependencies":  {
                         "@nestjs/common":  "^10.4.15",
                         "@nestjs/core":  "^10.4.15",
                         "@nestjs/jwt":  "^10.2.0",
                         "@nestjs/passport":  "^10.0.3",
                         "@nestjs/platform-express":  "^10.4.15",
                         "@prisma/client":  "^6.4.1",
                         "@vpos/ai-ready": "workspace:*",
                         "argon2":  "^0.41.1",
                         "class-transformer":  "^0.5.1",
                         "class-validator":  "^0.14.1",
                         "passport":  "^0.7.0",
                         "reflect-metadata":  "^0.2.2",
                         "rxjs":  "^7.8.1",
                         "uuid":  "^11.1.0",
                         "@vpos/shared-types":  "workspace:*"
                     },
    "devDependencies":  {
                            "@nestjs/testing":  "^10.4.15",
                            "@types/express":  "^5.0.0",
                            "@types/jest":  "^29.5.14",
                            "@types/passport-jwt":  "^4.0.1",
                            "@types/supertest":  "^6.0.2",
                            "jest":  "^29.7.0",
                            "prisma":  "^6.4.1",
                            "supertest":  "^7.0.0",
                            "ts-jest":  "^29.2.5",
                            "ts-node-dev":  "^2.0.0",
                            "tsx":  "^4.19.3"
                        }
}
