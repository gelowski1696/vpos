generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LocationType {
  BRANCH_STORE
  BRANCH_WAREHOUSE
  TRUCK
  PERSONNEL
}

enum CustomerType {
  RETAIL
  BUSINESS
}

enum PriceScope {
  GLOBAL
  BRANCH
  TIER
  CONTRACT
}

enum PriceFlowMode {
  ANY
  REFILL_EXCHANGE
  NON_REFILL
}

enum InventoryMovementType {
  SALE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  REFILL
  RETURN
}

enum TransferMode {
  SUPPLIER_RESTOCK_IN
  SUPPLIER_RESTOCK_OUT
  INTER_STORE_TRANSFER
  STORE_TO_WAREHOUSE
  WAREHOUSE_TO_STORE
  GENERAL
}

enum CostingMethod {
  WAC
  STANDARD
  LAST_PURCHASE
  MANUAL_OVERRIDE
}

enum CostAllocationBasis {
  PER_QUANTITY
  PER_WEIGHT
}

enum NegativeStockPolicy {
  BLOCK_POSTING
  ALLOW_WITH_REVIEW
}

enum CylinderOwnership {
  COMPANY
  CUSTOMER
}

enum CylinderStatus {
  FULL
  EMPTY
  DAMAGED
  LOST
}

enum CylinderEventType {
  ISSUE
  RETURN
  EXCHANGE
  TRANSFER
  REFILL
  DAMAGE
  LOSS
}

enum SaleType {
  PICKUP
  DELIVERY
}

enum PaymentMethod {
  CASH
  CARD
  E_WALLET
}

enum DeliveryStatus {
  CREATED
  ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum SyncReviewStatus {
  OPEN
  RESOLVED
}

enum AuditActionLevel {
  INFO
  WARNING
  CRITICAL
}

enum EntitlementStatus {
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

enum EntitlementBranchMode {
  SINGLE
  MULTI
}

enum EntitlementInventoryMode {
  STORE_ONLY
  STORE_WAREHOUSE
}

enum TenancyDatastoreMode {
  SHARED_DB
  DEDICATED_DB
}

enum TenancyMigrationState {
  NONE
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model Company {
  id            String                   @id @default(uuid())
  code          String                   @unique
  externalClientId String?               @unique
  name          String
  currencyCode  String                   @default("PHP")
  timezone      String                   @default("Asia/Manila")
  subscriptionStatus EntitlementStatus   @default(ACTIVE)
  entitlementUpdatedAt DateTime?
  datastoreMode TenancyDatastoreMode     @default(SHARED_DB)
  datastoreRef  String?
  datastoreMigrationState TenancyMigrationState @default(NONE)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  branding          BrandingConfig?
  entitlement       CompanyEntitlement?
  entitlementEvents CompanyEntitlementEvent[]
  branches          Branch[]
  locations         Location[]
  users             User[]
  personnelRoles    PersonnelRole[]
  personnels        Personnel[]
  roles             Role[]
  priceRules        PriceRule[]
  customers         Customer[]
  suppliers         Supplier[]
  products          Product[]
  productCategories ProductCategory[]
  productBrands     ProductBrand[]
  cylinderTypes     CylinderType[]
  priceLists        PriceList[]
  expenseCategories ExpenseCategory[]
  inventoryBalances InventoryBalance[]
  inventoryLedgers  InventoryLedger[]
  stockTransfers    StockTransfer[]
  costingConfig     CostingConfig?
  cylinders         Cylinder[]
  cylinderEvents    CylinderEvent[]
  cylinderBalances  CylinderBalance[]
  shifts            Shift[]
  sales             Sale[]
  deliveryOrders    DeliveryOrder[]
  pettyCashEntries  PettyCashEntry[]
  customerPayments  CustomerPayment[]
  depositLedger     DepositLiabilityLedger[]
  syncCursors       SyncCursor[]
  syncReviews       SyncReview[]
  idempotencyKeys   IdempotencyKey[]
  auditLogs         AuditLog[]
  eventSales        EventSales[]
  eventStock        EventStockMovement[]
  eventDelivery     EventDeliveryPerformance[]
  eventBehavior     EventUserBehavior[]
  tenantDatastores  TenantDatastoreRegistry[]
  mobileEnrollmentTokens MobileEnrollmentToken[]
}

model TenantDatastoreRegistry {
  id           String   @id @default(uuid())
  companyId    String
  datastoreRef String
  encryptedUrl String   @db.Text
  iv           String
  authTag      String
  keyVersion   String   @default("v1")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, datastoreRef])
  @@index([datastoreRef])
  @@index([companyId, updatedAt])
}

model CompanyEntitlement {
  id            String                    @id @default(uuid())
  companyId     String                    @unique
  externalClientId String
  status        EntitlementStatus         @default(ACTIVE)
  maxBranches   Int                       @default(1)
  branchMode    EntitlementBranchMode     @default(SINGLE)
  inventoryMode EntitlementInventoryMode  @default(STORE_ONLY)
  allowDelivery Boolean                   @default(false)
  allowTransfers Boolean                  @default(false)
  allowMobile   Boolean                   @default(true)
  graceUntil    DateTime?
  lastSyncedAt  DateTime                  @default(now())
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  events  CompanyEntitlementEvent[]

  @@index([externalClientId, status])
}

model CompanyEntitlementEvent {
  id             String    @id @default(uuid())
  companyId      String
  entitlementId  String?
  externalEventId String?  @unique
  eventType      String
  source         String    @default("WEBHOOK")
  payload        Json
  createdAt      DateTime  @default(now())

  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entitlement CompanyEntitlement? @relation(fields: [entitlementId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
}

model BrandingConfig {
  id                   String   @id @default(uuid())
  companyId            String   @unique
  companyName          String
  companyLogo          String?
  logoLight            String?
  logoDark             String?
  receiptLogo          String?
  primaryColor         String   @default("#0B3C5D")
  secondaryColor       String   @default("#328CC1")
  receiptFooterText    String?  @db.Text
  invoiceNumberFormat  String   @default("{BRANCH}-{YYYY}-{SEQ}")
  officialNumberFormat String   @default("OR-{YYYY}-{SEQ}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Branch {
  id         String   @id @default(uuid())
  companyId  String
  code       String
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  locations      Location[]
  priceLists     PriceList[]
  shifts         Shift[]
  sales          Sale[]
  pettyCash      PettyCashEntry[]
  receipts       Receipt[]
  deliveryOrders DeliveryOrder[]
  customerPayments CustomerPayment[]
  mobileEnrollmentTokens MobileEnrollmentToken[]
  personnels      Personnel[]

  @@unique([companyId, code])
  @@index([companyId, updatedAt])
}

model PersonnelRole {
  id         String   @id @default(uuid())
  companyId  String
  code       String
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  personnels Personnel[]

  @@unique([companyId, code])
  @@index([companyId, updatedAt])
}

model Personnel {
  id              String   @id @default(uuid())
  companyId       String
  branchId        String
  code            String
  fullName        String
  personnelRoleId String
  phone           String?
  email           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch  Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  role    PersonnelRole @relation(fields: [personnelRoleId], references: [id], onDelete: Restrict)

  @@unique([companyId, code])
  @@index([companyId, branchId, updatedAt])
  @@index([personnelRoleId])
}

model Location {
  id          String       @id @default(uuid())
  companyId   String
  branchId    String?
  code        String
  name        String
  type        LocationType
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch             Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  inventoryBalances  InventoryBalance[]
  inventoryLedgers   InventoryLedger[]
  sourceTransfers    StockTransfer[]    @relation("TransferSource")
  destinationTransfers StockTransfer[]  @relation("TransferDestination")
  cylinders          Cylinder[]
  cylinderEventsFrom CylinderEvent[]    @relation("CylinderEventFrom")
  cylinderEventsTo   CylinderEvent[]    @relation("CylinderEventTo")
  cylinderBalances   CylinderBalance[]
  sales              Sale[]
  syncCursors        SyncCursor[]
  suppliers          Supplier[]
  mobileEnrollmentTokens MobileEnrollmentToken[]

  @@unique([companyId, code])
  @@index([companyId, updatedAt])
}

model User {
  id           String   @id @default(uuid())
  companyId    String
  branchId     String?
  email        String
  fullName     String
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company             Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userRoles           UserRole[]
  supervisorPin       SupervisorPin?
  refreshTokens       RefreshToken[]
  deviceSessions      DeviceSession[]
  shifts              Shift[]
  sales               Sale[]
  deliveryAssignments DeliveryAssignment[]
  pettyCashEntries    PettyCashEntry[]
  auditLogs           AuditLog[]
  discountOverrides   DiscountOverrideLog[]
  requestedTransfers  StockTransfer[]
  postedCustomerPayments CustomerPayment[]
  mobileEnrollmentTokens MobileEnrollmentToken[] @relation("MobileEnrollmentUser")
  createdMobileEnrollmentTokens MobileEnrollmentToken[] @relation("MobileEnrollmentCreator")

  @@unique([companyId, email])
  @@index([companyId, updatedAt])
}

model MobileEnrollmentToken {
  id              String   @id @default(uuid())
  companyId       String
  userId          String
  branchId        String
  locationId      String
  createdByUserId String?
  tokenHash       String   @unique
  expiresAt       DateTime
  usedAt          DateTime?
  revokedAt       DateTime?
  claimedDeviceId String?
  claimedIp       String?
  claimedUserAgent String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation("MobileEnrollmentUser", fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  location  Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("MobileEnrollmentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, userId, createdAt])
  @@index([companyId, expiresAt, usedAt, revokedAt])
}

model Role {
  id         String   @id @default(uuid())
  companyId  String
  name       String
  createdAt  DateTime @default(now())

  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userRoles    UserRole[]
  permissions  RolePermission[]

  @@unique([companyId, name])
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model SupervisorPin {
  id         String   @id @default(uuid())
  userId     String   @unique
  pinHash    String
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  jti         String   @unique
  tokenHash   String
  expiresAt   DateTime
  revokedAt   DateTime?
  replacedBy  String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeviceSession {
  id              String   @id @default(uuid())
  userId          String
  deviceId        String
  platform        String
  lastSyncToken   String?
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
}

model Customer {
  id                String       @id @default(uuid())
  companyId         String
  code              String
  name              String
  type              CustomerType
  tier              String?
  contractPrice     Decimal?     @db.Decimal(12, 2)
  depositBalance    Decimal      @default(0) @db.Decimal(12, 2)
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales   Sale[]
  customerPayments CustomerPayment[]

  @@unique([companyId, code])
  @@index([companyId, updatedAt])
}

model Supplier {
  id            String   @id @default(uuid())
  companyId     String
  locationId    String?
  code          String
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@unique([companyId, code])
  @@index([companyId, updatedAt])
  @@index([companyId, locationId])
}

model Product {
  id                String    @id @default(uuid())
  companyId         String
  sku               String
  name              String
  category          String?
  brand             String?
  isLpg             Boolean   @default(false)
  cylinderTypeId    String?
  standardCost      Decimal?  @db.Decimal(14, 4)
  lowStockAlertQty  Decimal?  @db.Decimal(14, 4)
  unit              String
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cylinderType      CylinderType?      @relation(fields: [cylinderTypeId], references: [id], onDelete: SetNull)
  priceRules        PriceRule[]
  inventoryBalances InventoryBalance[]
  inventoryLedgers  InventoryLedger[]
  transferLines     StockTransferLine[]
  saleLines         SaleLine[]

  @@unique([companyId, sku])
  @@index([companyId, updatedAt])
}

model ProductCategory {
  id         String   @id @default(uuid())
  companyId  String
  code       String
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@index([companyId, updatedAt])
}

model ProductBrand {
  id         String   @id @default(uuid())
  companyId  String
  code       String
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
  @@index([companyId, updatedAt])
}

model CylinderType {
  id            String   @id @default(uuid())
  companyId     String
  code          String
  name          String
  sizeKg        Decimal  @db.Decimal(8, 2)
  depositAmount Decimal  @db.Decimal(12, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products        Product[]
  cylinders       Cylinder[]
  cylinderBalance CylinderBalance[]

  @@unique([companyId, code])
}

model PriceList {
  id            String    @id @default(uuid())
  companyId     String
  code          String
  branchId      String?
  name          String
  scope         PriceScope
  customerTier  String?
  customerId    String?
  startsAt      DateTime
  endsAt        DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  rules     PriceRule[]

  @@unique([companyId, code])
  @@index([companyId, startsAt, endsAt])
}

model PriceRule {
  id                String    @id @default(uuid())
  companyId         String
  priceListId       String
  productId         String
  flowMode          PriceFlowMode @default(ANY)
  unitPrice         Decimal   @db.Decimal(12, 2)
  discountCapPct    Decimal   @default(0) @db.Decimal(5, 2)
  priority          Int
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId, productId, flowMode, priority])
}

model ExpenseCategory {
  id         String   @id @default(uuid())
  companyId  String
  code       String
  name       String
  isActive   Boolean  @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pettyCashEntries PettyCashEntry[]

  @@unique([companyId, code])
}

model InventoryBalance {
  id          String   @id @default(uuid())
  companyId   String
  locationId  String
  productId   String
  qtyOnHand   Decimal  @default(0) @db.Decimal(14, 4)
  avgCost     Decimal  @default(0) @db.Decimal(14, 4)
  updatedAt   DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId])
  @@index([companyId, updatedAt])
}

model InventoryLedger {
  id                String                @id @default(uuid())
  companyId         String
  locationId        String
  productId         String
  movementType      InventoryMovementType
  referenceType     String
  referenceId       String
  qtyDelta          Decimal               @db.Decimal(14, 4)
  unitCost          Decimal               @db.Decimal(14, 4)
  avgCostAfter      Decimal               @db.Decimal(14, 4)
  qtyAfter          Decimal               @db.Decimal(14, 4)
  createdAt         DateTime              @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([locationId, productId])
}

model StockTransfer {
  id                    String   @id @default(uuid())
  companyId             String
  sourceLocationId      String
  destinationLocationId String
  shiftId               String?
  transferMode          TransferMode @default(GENERAL)
  supplierId            String?
  supplierName          String?
  sourceLocationLabel   String?
  destinationLocationLabel String?
  status                String
  requestedByUserId     String
  postedAt              DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company              Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceLocation       Location    @relation("TransferSource", fields: [sourceLocationId], references: [id], onDelete: Restrict)
  destinationLocation  Location    @relation("TransferDestination", fields: [destinationLocationId], references: [id], onDelete: Restrict)
  shift                Shift?      @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  requestedBy          User        @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)
  lines                StockTransferLine[]

  @@index([shiftId])
  @@index([companyId, transferMode, createdAt])
}

model StockTransferLine {
  id          String   @id @default(uuid())
  transferId  String
  productId   String
  qtyFull     Decimal  @default(0) @db.Decimal(14, 4)
  qtyEmpty    Decimal  @default(0) @db.Decimal(14, 4)

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model CostingConfig {
  id          String   @id @default(uuid())
  companyId   String   @unique
  method      CostingMethod @default(WAC)
  allowManualOverride Boolean @default(false)
  negativeStockPolicy NegativeStockPolicy @default(BLOCK_POSTING)
  includeFreight Boolean @default(false)
  includeHandling Boolean @default(false)
  includeOtherLandedCost Boolean @default(false)
  allocationBasis CostAllocationBasis @default(PER_QUANTITY)
  roundingScale Int @default(4)
  locked      Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Cylinder {
  id                String            @id @default(uuid())
  companyId         String
  serial            String            @unique
  cylinderTypeId    String
  ownership         CylinderOwnership
  status            CylinderStatus
  currentLocationId String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cylinderType    CylinderType  @relation(fields: [cylinderTypeId], references: [id], onDelete: Restrict)
  currentLocation Location      @relation(fields: [currentLocationId], references: [id], onDelete: Restrict)
  events          CylinderEvent[]

  @@index([companyId, updatedAt])
  @@index([currentLocationId, status])
}

model CylinderEvent {
  id               String           @id @default(uuid())
  companyId        String
  cylinderId       String
  eventType        CylinderEventType
  fromLocationId   String?
  toLocationId     String?
  actorUserId      String?
  notes            String?
  createdAt        DateTime         @default(now())

  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cylinder      Cylinder  @relation(fields: [cylinderId], references: [id], onDelete: Cascade)
  fromLocation  Location? @relation("CylinderEventFrom", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocation    Location? @relation("CylinderEventTo", fields: [toLocationId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
}

model CylinderBalance {
  id            String   @id @default(uuid())
  companyId     String
  locationId    String
  cylinderTypeId String
  qtyFull       Int      @default(0)
  qtyEmpty      Int      @default(0)
  updatedAt     DateTime @updatedAt

  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location     Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  cylinderType CylinderType @relation(fields: [cylinderTypeId], references: [id], onDelete: Cascade)

  @@unique([locationId, cylinderTypeId])
}

model Shift {
  id              String      @id @default(uuid())
  companyId       String
  branchId        String
  userId          String
  openedAt        DateTime
  closedAt        DateTime?
  openingCash     Decimal     @db.Decimal(12, 2)
  closingCash     Decimal?    @db.Decimal(12, 2)
  status          ShiftStatus @default(OPEN)
  createdAt       DateTime    @default(now())

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch          Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  user            User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  cashEntries     ShiftCashEntry[]
  zRead           ZRead?
  sales           Sale[]
  pettyCash       PettyCashEntry[]
  transfers       StockTransfer[]
}

model ShiftCashEntry {
  id         String   @id @default(uuid())
  shiftId    String
  direction  String
  amount     Decimal  @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime @default(now())

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model ZRead {
  id          String   @id @default(uuid())
  shiftId     String   @unique
  totalSales  Decimal  @db.Decimal(14, 2)
  totalCash   Decimal  @db.Decimal(14, 2)
  generatedAt DateTime @default(now())

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model Sale {
  id             String    @id @default(uuid())
  companyId      String
  branchId       String
  locationId     String
  shiftId        String?
  userId         String
  customerId     String?
  saleType       SaleType
  subtotal       Decimal   @db.Decimal(14, 2)
  discountAmount Decimal   @default(0) @db.Decimal(14, 2)
  totalAmount    Decimal   @db.Decimal(14, 2)
  cogsAmount     Decimal?  @db.Decimal(14, 2)
  postedAt       DateTime?
  createdAt      DateTime  @default(now())

  company          Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch           Branch                   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  location         Location                 @relation(fields: [locationId], references: [id], onDelete: Restrict)
  shift            Shift?                   @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  user             User                     @relation(fields: [userId], references: [id], onDelete: Restrict)
  customer         Customer?                @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lines            SaleLine[]
  payments         Payment[]
  customerPayments CustomerPayment[]
  receipt          Receipt?
  deliveryOrder    DeliveryOrder?
  discountOverride DiscountOverrideLog[]
}

model SaleLine {
  id              String   @id @default(uuid())
  saleId          String
  productId       String
  quantity        Decimal  @db.Decimal(14, 4)
  unitPrice       Decimal  @db.Decimal(12, 2)
  estimatedCost   Decimal? @db.Decimal(12, 2)
  lineTotal       Decimal  @db.Decimal(14, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Payment {
  id         String        @id @default(uuid())
  saleId      String
  method      PaymentMethod
  amount      Decimal       @db.Decimal(14, 2)
  referenceNo String?

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model CustomerPayment {
  id              String        @id @default(uuid())
  companyId       String
  branchId        String?
  saleId          String?
  customerId      String
  createdByUserId String?
  method          PaymentMethod
  amount          Decimal       @db.Decimal(14, 2)
  referenceNo     String?
  notes           String?
  postedAt        DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  sale          Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdByUser User?    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, postedAt])
  @@index([companyId, customerId, postedAt])
  @@index([companyId, saleId, postedAt])
  @@index([branchId, postedAt])
}

model DiscountOverrideLog {
  id               String   @id @default(uuid())
  saleId           String
  supervisorUserId String
  reason           String
  createdAt        DateTime @default(now())

  sale           Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  supervisorUser User @relation(fields: [supervisorUserId], references: [id], onDelete: Restrict)
}

model Receipt {
  id            String   @id @default(uuid())
  saleId         String   @unique
  branchId       String
  receiptNumber  String
  isReprint      Boolean  @default(false)
  printedAt      DateTime @default(now())

  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([branchId, receiptNumber])
}

model DeliveryOrder {
  id               String         @id @default(uuid())
  companyId        String
  branchId         String
  saleId           String?        @unique
  status           DeliveryStatus @default(CREATED)
  scheduledAt      DateTime?
  completedAt      DateTime?
  createdAt        DateTime       @default(now())

  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch                @relation(fields: [branchId], references: [id], onDelete: Restrict)
  sale        Sale?                 @relation(fields: [saleId], references: [id], onDelete: SetNull)
  assignments DeliveryAssignment[]
  events      DeliveryStatusEvent[]
}

model DeliveryAssignment {
  id              String   @id @default(uuid())
  deliveryOrderId String
  userId          String
  role            String
  assignedAt      DateTime @default(now())

  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)
}

model DeliveryStatusEvent {
  id              String         @id @default(uuid())
  deliveryOrderId String
  status          DeliveryStatus
  notes           String?
  createdAt       DateTime       @default(now())

  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
}

model PettyCashEntry {
  id                String   @id @default(uuid())
  companyId         String
  branchId          String
  shiftId           String
  userId            String
  expenseCategoryId String
  direction         String
  amount            Decimal  @db.Decimal(12, 2)
  notes             String?
  createdAt         DateTime @default(now())

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch          Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  shift           Shift           @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  user            User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  expenseCategory ExpenseCategory @relation(fields: [expenseCategoryId], references: [id], onDelete: Restrict)
}

model DepositLiabilityLedger {
  id          String   @id @default(uuid())
  companyId   String
  customerId  String?
  saleId      String?
  direction   String
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model SyncCursor {
  id             String   @id @default(uuid())
  companyId      String
  locationId     String?
  deviceId       String
  token          String
  lastPulledAt   DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@unique([companyId, deviceId])
}

model SyncReview {
  id          String           @id @default(uuid())
  companyId   String
  outboxId    String
  entity      String
  reason      String
  payload     Json
  status      SyncReviewStatus @default(OPEN)
  createdAt   DateTime         @default(now())
  resolvedAt  DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status, createdAt])
}

model IdempotencyKey {
  id          String   @id @default(uuid())
  companyId   String
  key         String
  requestHash String
  response    Json?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
}

model AuditLog {
  id          String         @id @default(uuid())
  companyId   String
  userId      String?
  action      String
  level       AuditActionLevel @default(INFO)
  entity      String
  entityId    String?
  metadata    Json?
  createdAt   DateTime       @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
}

model EventSales {
  id          String   @id @default(uuid())
  companyId   String
  branchId    String?
  saleId      String
  happenedAt  DateTime
  payload     Json
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, happenedAt])
}

model EventStockMovement {
  id          String   @id @default(uuid())
  companyId   String
  locationId  String?
  ledgerId    String
  happenedAt  DateTime
  payload     Json
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, happenedAt])
}

model EventDeliveryPerformance {
  id              String   @id @default(uuid())
  companyId       String
  deliveryOrderId String
  happenedAt      DateTime
  payload         Json
  createdAt       DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, happenedAt])
}

model EventUserBehavior {
  id          String   @id @default(uuid())
  companyId   String
  userId      String?
  happenedAt  DateTime
  payload     Json
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, happenedAt])
}

// NOTE: Postgres CHECK constraints for non-negative deposits and state transitions
// should be added in SQL migrations for production hardening.
